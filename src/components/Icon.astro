---
// Inline SVG icons — no runtime library. Line icons use currentColor stroke;
// brand icons use currentColor fill.
interface Props {
  name:
    | "arrow-right"
    | "arrow-down"
    | "arrow-up-right"
    | "arrow-left"
    | "github"
    | "linkedin"
    | "mail"
    | "download"
    | "file"
    | "copy"
    | "check"
    | "chevron-right";
  class?: string;
}
const { name, class: className } = Astro.props;
const stroke = "stroke-width='1.7' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round'";
const cls = `icon ${className ?? ""}`.trim();
---

{name === "arrow-right" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M5 12h14M13 6l6 6-6 6'/>`} />
)}
{name === "arrow-down" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M12 5v14M6 13l6 6 6-6'/>`} />
)}
{name === "arrow-left" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M19 12H5M11 18l-6-6 6-6'/>`} />
)}
{name === "arrow-up-right" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M7 17 17 7M8 7h9v9'/>`} />
)}
{name === "chevron-right" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M9 6l6 6-6 6'/>`} />
)}
{name === "mail" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<rect ${stroke} x='3' y='5' width='18' height='14' rx='2'/><path ${stroke} d='m4 7 8 6 8-6'/>`} />
)}
{name === "download" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M12 3v12M8 11l4 4 4-4M5 21h14'/>`} />
)}
{name === "file" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z'/><path ${stroke} d='M14 3v5h5M9 13h6M9 17h6'/>`} />
)}
{name === "copy" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<rect ${stroke} x='9' y='9' width='12' height='12' rx='2'/><path ${stroke} d='M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1'/>`} />
)}
{name === "check" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path ${stroke} d='M4 12.5 9 17.5 20 6.5'/>`} />
)}
{name === "github" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path fill='currentColor' d='M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.34 9.34 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z'/>`} />
)}
{name === "linkedin" && (
  <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" set:html={`<path fill='currentColor' d='M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14M7.12 20.45H3.56V9h3.56zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0'/>`} />
)}

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { projects, profile } from "../../data/portfolio";
import { projectHref, resolveUrl, withBase } from "../../lib/links";

export function getStaticPaths() {
  // External-only projects (e.g. the live demo) link out and have no case-study page.
  const pageable = projects.filter((p) => !p.externalUrl);
  return pageable.map((project, i) => ({
    params: { slug: project.slug },
    props: {
      project,
      prev: pageable[(i - 1 + pageable.length) % pageable.length],
      next: pageable[(i + 1) % pageable.length],
    },
  }));
}

const { project, prev, next } = Astro.props;
const detailParas = Array.isArray(project.detail) ? project.detail : [project.detail];
const hasStructured = Boolean(project.problem || project.build || project.architecture);
const linkIcon = (kind: string) =>
  kind === "repo" ? "github" : kind === "paper" || kind === "thesis" || kind === "writeup" ? "file" : "arrow-up-right";

const title = `${project.title} · ${profile.name}`;
const description = project.subtitle ?? project.summary;
---

<BaseLayout title={title} description={description}>
  <main id="main">
    <section class="section case-hero">
      <div class="container">
        <a class="back-link reveal" href={withBase("#work")}>
          <Icon name="arrow-left" class="arrow" /> All work
        </a>

        <p class="eyebrow case-eyebrow reveal">{project.eyebrow}</p>
        <h1 class="case-title reveal">{project.title}</h1>
        <p class="case-sub reveal">{project.subtitle ?? project.summary}</p>

        {project.roleFit && (
          <ul class="case-rolefit reveal" aria-label="Role fit">
            {project.roleFit.map((r) => <li class="chip chip--role">{r}</li>)}
          </ul>
        )}

        {project.links && (
          <div class="case-actions reveal">
            {project.links.map((link, i) => (
              <a
                class={`btn ${i === 0 ? "btn--primary" : "btn--secondary"}`}
                href={resolveUrl(link.url)}
                target="_blank"
                rel="noreferrer"
              >
                <Icon name={linkIcon(link.kind)} />
                {link.label}
              </a>
            ))}
          </div>
        )}

        {project.metrics && (
          <div class="case-metrics reveal">
            {project.metrics.map((m) => (
              <div>
                <div class="v">{m.value}</div>
                <div class="l">{m.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container case-body">
        <div class="case-main">
          <div class="case-block reveal">
            <h2>Overview</h2>
            {detailParas.map((p) => <p>{p}</p>)}
          </div>

          {project.problem && (
            <div class="case-block reveal">
              <h2>Problem</h2>
              <p>{project.problem}</p>
            </div>
          )}

          {project.constraints && (
            <div class="case-block reveal">
              <h2>Constraints</h2>
              <ul>{project.constraints.map((c) => <li>{c}</li>)}</ul>
            </div>
          )}

          {project.build && (
            <div class="case-block reveal">
              <h2>What I built</h2>
              <ul>{project.build.map((b) => <li>{b}</li>)}</ul>
            </div>
          )}

          {project.architecture && (
            <div class="case-block reveal">
              <h2>Architecture</h2>
              <ul>{project.architecture.map((a) => <li>{a}</li>)}</ul>
            </div>
          )}

          {project.decisions && (
            <div class="case-block reveal">
              <h2>Key implementation decisions</h2>
              <div class="decisions">
                {project.decisions.map((d) => (
                  <div class="decision">
                    <h3>{d.title}</h3>
                    <p>{d.body}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {project.evaluation && (
            <div class="case-block reveal">
              <h2>Evaluation &amp; impact</h2>
              <ul>{project.evaluation.map((e) => <li>{e}</li>)}</ul>
            </div>
          )}

          {!hasStructured && project.impact && (
            <div class="case-block reveal">
              <h2>Highlights</h2>
              <ul>{project.impact.map((e) => <li>{e}</li>)}</ul>
            </div>
          )}

          {project.improvements && (
            <div class="case-block reveal">
              <h2>What I'd improve next</h2>
              <ul>{project.improvements.map((e) => <li>{e}</li>)}</ul>
            </div>
          )}
        </div>

        <aside class="case-aside reveal">
          <div class="aside-block">
            <h4>Stack</h4>
            <ul class="tags">{project.stack.map((s) => <li>{s}</li>)}</ul>
          </div>
          {project.links && (
            <div class="aside-block">
              <h4>Links</h4>
              <div class="links-list">
                {project.links.map((link) => (
                  <a href={resolveUrl(link.url)} target="_blank" rel="noreferrer">
                    <Icon name={linkIcon(link.kind)} /> {link.label}
                  </a>
                ))}
                <a href={withBase(profile.cvPath)} target="_blank" rel="noreferrer">
                  <Icon name="download" /> Download CV
                </a>
              </div>
            </div>
          )}
        </aside>
      </div>

      <div class="container">
        <nav class="case-nav" aria-label="More projects">
          <a class="prev" href={projectHref(prev.slug)}>
            <span>← Previous</span>
            <b>{prev.title}</b>
          </a>
          <a class="next" href={projectHref(next.slug)}>
            <span>Next →</span>
            <b>{next.title}</b>
          </a>
        </nav>
      </div>
    </section>
  </main>
</BaseLayout>

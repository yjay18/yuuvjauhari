---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { withBase } from "../lib/links";
---

<BaseLayout title="Page not found · Yuuv Jauhari">
  <main id="main" class="notfound">
    <div>
      <p class="eyebrow" style="justify-content:center">Error 404</p>
      <p class="code serif">Not found</p>
      <p>That page doesn't exist. The portfolio, projects, and research all live on the home page.</p>
      <a class="btn btn--primary" href={withBase("")}>
        Return home
        <Icon name="arrow-right" class="arrow" />
      </a>
    </div>
  </main>
</BaseLayout>

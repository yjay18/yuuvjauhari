---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FlagshipCard from "../components/FlagshipCard.astro";
import Icon from "../components/Icon.astro";
import {
  archiveFilters,
  communityHighlights,
  credibility,
  education,
  experience,
  flagshipProjects,
  profile,
  projects,
  publications,
  skillGroups,
  targetRoles,
} from "../data/portfolio";
import { projectHref, resolveUrl, withBase } from "../lib/links";

const cv = withBase(profile.cvPath);
---

<BaseLayout>
  <main id="main">
    <Hero />

    {/* ---- Credibility strip -------------------------------------------- */}
    <section class="credibility" aria-label="Credibility">
      <div class="container">
        <div class="cred-row reveal">
          <span class="cred-label">Trusted context</span>
          {credibility.map((item) =>
            item.href ? (
              <a class="cred-item" href={resolveUrl(item.href)} target="_blank" rel="noreferrer">
                <b>{item.label}</b>
                {item.note && <span>{item.note}</span>}
              </a>
            ) : (
              <span class="cred-item">
                <b>{item.label}</b>
                {item.note && <span>{item.note}</span>}
              </span>
            )
          )}
        </div>
      </div>
    </section>

    {/* ---- Flagship work ------------------------------------------------ */}
    <section class="section" id="work" aria-labelledby="work-title">
      <div class="container">
        <div class="section-head reveal">
          <span class="index">01 · Selected work</span>
          <h2 class="section-title" id="work-title">Flagship projects</h2>
          <p class="lede">Selected work across research, ML systems, and applied engineering.</p>
        </div>

        <div class="work-grid">
          {flagshipProjects.map((project, i) => <FlagshipCard project={project} index={i} />)}
        </div>
      </div>
    </section>

    {/* ---- Experience --------------------------------------------------- */}
    <section class="section" id="experience" aria-labelledby="xp-title">
      <div class="container">
        <div class="section-head reveal">
          <span class="index">02 · Track record</span>
          <h2 class="section-title" id="xp-title">Experience</h2>
          <p class="lede">Across industry and research.</p>
        </div>

        <div class="xp-list">
          {experience.map((xp) => (
            <article class="xp reveal">
              <div class="xp-meta">
                <p class="yr">{xp.year}</p>
                <p class="co">{xp.company}</p>
                <p class="pl">{xp.period} · {xp.location}</p>
              </div>
              <div class="xp-body">
                <div class="role-row">
                  <span class="role">{xp.role}</span>
                  {xp.tag && <span class="tag">{xp.tag}</span>}
                </div>
                <p class="xp-summary">{xp.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---- Education ------------------------------------------------------- */}
    <section class="section" id="education" aria-labelledby="edu-title">
      <div class="container">
        <div class="section-head reveal">
          <span class="index">03 · Education</span>
          <h2 class="section-title" id="edu-title">Education</h2>
          <p class="lede">Where the foundation was built.</p>
        </div>

        <div class="edu-grid">
          {education.map((edu) => (
            <article class="edu-card reveal">
              <div class="edu-topline">
                <span>{edu.period}</span>
                <span>{edu.location}</span>
              </div>
              <div class="edu-main">
                <h3>{edu.institution}</h3>
                <p class="edu-degree">{edu.qualification}</p>
                {edu.tag && <span class="tag">{edu.tag}</span>}
              </div>
              <p>{edu.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---- Skills ------------------------------------------------------- */}
    <section class="section" id="skills" aria-labelledby="skills-title">
      <div class="container">
        <div class="section-head reveal">
          <span class="index">04 · Capabilities</span>
          <h2 class="section-title" id="skills-title">Skills</h2>
          <p class="lede">Grouped by area, with the projects where each was applied.</p>
        </div>

        <div class="skills-grid">
          {skillGroups.map((group) => (
            <article class="skill-card reveal">
              <h3>{group.title}</h3>
              <p class="caption">{group.caption}</p>
              <ul class="tags">
                {group.skills.map((s) => <li>{s}</li>)}
              </ul>
              <div class="applied">
                <span class="lbl">Applied in</span>
                {group.appliedIn.map((p) => (
                  <a href={projectHref(p.slug)}>
                    {p.label}
                    <Icon name="arrow-right" class="arrow" />
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---- Publications ------------------------------------------------- */}
    <section class="section" id="research" aria-labelledby="research-title">
      <div class="container">
        <div class="section-head reveal">
          <span class="index">05 · Research</span>
          <h2 class="section-title" id="research-title">Publications</h2>
          <p class="lede">Peer-reviewed, thesis, and preprint work.</p>
        </div>

        <div class="pub-list">
          {publications.map((pub) => {
            const Tag = pub.url ? "a" : "div";
            const attrs = pub.url
              ? { href: resolveUrl(pub.url), target: "_blank", rel: "noreferrer" }
              : {};
            return (
              <Tag class="pub reveal" {...attrs}>
                <div class="pub-when">
                  <span>{pub.date}</span>
                  {pub.status && <span class="status">{pub.status}</span>}
                </div>
                <div class="pub-main">
                  <h3>{pub.title}</h3>
                  {pub.subtitle && <p>{pub.subtitle}</p>}
                  <p class="venue">{pub.venue}</p>
                </div>
                {pub.url && <Icon name="arrow-up-right" class="pub-go" />}
              </Tag>
            );
          })}
        </div>
      </div>
    </section>

    {/* ---- All projects ------------------------------------------------- */}
    <section class="section" id="archive" aria-labelledby="archive-title">
      <div class="container">
        <div class="archive-head reveal">
          <div class="section-head" style="margin-bottom:0">
            <span class="index">06 · All work</span>
            <h2 class="section-title" id="archive-title">All projects</h2>
            <p class="lede">The complete set, from flagship work to experiments and community projects.</p>
          </div>
          <div class="filters" role="group" aria-label="Filter projects" data-filters>
            {archiveFilters.map((f, i) => (
              <button class="filter" type="button" data-filter={f} aria-pressed={i === 0 ? "true" : "false"}>
                {f}
              </button>
            ))}
          </div>
        </div>

        <div class="archive-grid" data-archive>
          {projects.map((p) => {
            const external = Boolean(p.externalUrl);
            const linkAttrs = external
              ? { href: p.externalUrl, target: "_blank", rel: "noreferrer" }
              : { href: projectHref(p.slug) };
            return (
              <a class="acard reveal" {...linkAttrs} data-cats={p.categories.join("|")}>
                {p.flagship && <span class="ac-flag">Flagship</span>}
                <span class="ac-eyebrow">{p.eyebrow}</span>
                <h3>{p.title}</h3>
                <p>{p.subtitle ?? p.summary}</p>
                <span class="ac-foot">
                  <span>{p.categories[0]}</span>
                  <span class="go">{external ? "Live demo →" : "Case study →"}</span>
                </span>
              </a>
            );
          })}
          {communityHighlights.map((c) => (
            <div class="acard acard--static reveal" data-cats={c.categories.join("|")}>
              <span class="ac-eyebrow">{c.eyebrow}</span>
              <h3>{c.title}</h3>
              <p>{c.summary}</p>
              <span class="ac-foot">
                <span>{c.period}</span>
                <span>{c.categories[0]}</span>
              </span>
            </div>
          ))}
          <p class="archive-empty" data-archive-empty hidden>No projects in this category.</p>
        </div>
      </div>
    </section>

    {/* ---- Contact ------------------------------------------------------ */}
    <section class="section" id="contact" aria-labelledby="contact-title">
      <div class="container contact-grid">
        <div class="contact-lead reveal">
          <span class="eyebrow">07 · Contact</span>
          <h2 id="contact-title" style="margin-top:0.9rem">
            Interested in systems that are both <span class="accent-word">researched</span> and built?
          </h2>
          <p>
            I'm open to roles across AI/ML, NLP, and LLM systems, as well as software engineering
            more generally, where I can contribute from research and evaluation through to production.
          </p>
          <div class="contact-actions">
            <a class="btn btn--primary" href={`mailto:${profile.email}`}>
              <Icon name="mail" /> Email me
            </a>
            <button class="btn btn--secondary copy-mail" type="button" data-copy={profile.email}>
              <Icon name="copy" /> Copy email
            </button>
            <span class="copy-ok" data-copy-ok aria-live="polite"></span>
            <a class="btn btn--secondary" href={cv} target="_blank" rel="noreferrer">
              <Icon name="download" /> Download CV
            </a>
          </div>
        </div>

        <aside class="recruiter reveal" aria-label="Recruiter summary">
          <div class="recruiter-head">
            <span class="rh-title">Recruiter summary</span>
            <span class="avail">{profile.availability}</span>
          </div>
          <dl>
            <div>
              <dt>Roles</dt>
              <dd>
                <div class="roles">
                  {targetRoles.map((r) => <span>{r}</span>)}
                </div>
              </dd>
            </div>
            <div>
              <dt>Location</dt>
              <dd>{profile.location}</dd>
            </div>
            <div>
              <dt>Degree</dt>
              <dd>{profile.degree} · {profile.degreeNote}</dd>
            </div>
            <div>
              <dt>Email</dt>
              <dd><a href={`mailto:${profile.email}`}>{profile.email}</a></dd>
            </div>
            <div>
              <dt>Updated</dt>
              <dd>{profile.lastUpdated}</dd>
            </div>
          </dl>
          <div class="recruiter-actions">
            <a class="btn btn--primary" href={cv} target="_blank" rel="noreferrer">
              <Icon name="download" /> CV
            </a>
            <a class="btn btn--secondary" href={`mailto:${profile.email}`}>
              <Icon name="mail" /> Email
            </a>
            <a class="btn btn--secondary" href={profile.github} target="_blank" rel="noreferrer">
              <Icon name="github" /> GitHub
            </a>
            <a class="btn btn--secondary" href={profile.linkedin} target="_blank" rel="noreferrer">
              <Icon name="linkedin" /> LinkedIn
            </a>
          </div>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
